# Microsoft Entra ID / Azure AD Configuration
# Copy this file to .env.local and fill in your values from Azure Portal

# Frontend Entra App Registration
VITE_ENTRA_CLIENT_ID=<your-frontend-app-registration-client-id>
VITE_ENTRA_TENANT_ID=<your-tenant-id>
VITE_ENTRA_AUTHORITY=https://login.microsoftonline.com/<your-tenant-id>

# API scope - format: api://<backend-client-id>/access_as_user
VITE_API_SCOPES=api://<your-backend-client-id>/access_as_user

# Redirect URI (must match Azure app registration)
VITE_API_REDIRECT_URI=http://localhost:5173

# Optional popup callback page for loginPopup (recommended to avoid popup showing the full app)
VITE_ENTRA_POPUP_REDIRECT_URI=http://localhost:5173/auth-popup.html
